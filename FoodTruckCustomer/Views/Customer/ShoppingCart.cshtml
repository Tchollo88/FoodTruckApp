@using Repository.Models.Menu
@using FoodTruckCustomer.Controllers
@using Repository.Models.Cart

<h2>Your Shopping Cart</h2>

@if (Model.Items.Any())
{
    <table>
        <thead>
            <tr>
                <th>Item Name</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Total</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Price</td>
                    <td>@item.Quantity</td>
                    <td>@(item.Price * item.Quantity)</td>
                    <td>
                        <a href="@Url.Action("RemoveFromCart", "Cart", new { itemId = item.ItemId })">Remove</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <h3>Total: @Model.GetTotal()</h3>
    <a href="@Url.Action("Checkout", "Cart")">Proceed to Checkout</a>
}
else
{
    <p>Your cart is empty.</p>
}
